<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    tools:background="@drawable/mapbox_voice_feedback_bg_button"
    tools:parentTag="android.widget.FrameLayout">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="@dimen/mapbox_voice_feedback_button_size"
        android:layout_height="@dimen/mapbox_voice_feedback_button_size">

        <ImageView
            android:id="@+id/iconImage"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="@dimen/mapbox_voice_feedback_button_icon_size"
            android:layout_height="@dimen/mapbox_voice_feedback_button_icon_size"
            android:contentDescription="@null"
            android:src="@drawable/mapbox_ic_voice_feedback" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</merge>
